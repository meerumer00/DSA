#include <stdio.h>
#include <string.h>

int main() {
    char s[101], stack[101];
    int top = -1;

    scanf("%s", s);

    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == '*') {
            top--;
        } else {
            stack[++top] = s[i];
        }
    }

    for (int i = 0; i <= top; i++) {
        printf("%c", stack[i]);
    }

    return 0;
}
