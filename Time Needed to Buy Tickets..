#include <stdio.h>

int main() {
    int n,k;
    scanf("%d",&n);
    
    int tickets[100];
    for(int i=0;i<n;i++)
        scanf("%d",&tickets[i]);
        
    scanf("%d",&k);
    
    int time=0;
    
    for(int i=0;i<n;i++){
        if(i<=k){
            time += tickets[i] < tickets[k] ? tickets[i] : tickets[k];
        } else {
            time += tickets[i] < tickets[k]-1 ? tickets[i] : tickets[k]-1;
        }
    }
    
    printf("%d",time);
    
    return 0;
}
