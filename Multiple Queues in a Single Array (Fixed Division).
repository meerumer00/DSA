#include <stdio.h>
#include <string.h>

int main(){
    int N,K,Q;
    scanf("%d %d",&N,&K);

    int size=N/K;
    int arr[100];
    int front[10],rear[10];

    for(int i=0;i<K;i++){
        front[i]=-1;
        rear[i]=-1;
    }

    scanf("%d",&Q);

    while(Q--){
        char op[10];
        int q,x;
        scanf("%s",op);

        if(strcmp(op,"ENQUEUE")==0){
            scanf("%d %d",&q,&x);
            q--;

            if(rear[q]==size-1){
                printf("Queue Overflow\n");
            }else{
                if(front[q]==-1) front[q]=0;
                rear[q]++;
                arr[q*size + rear[q]]=x;
            }
        }

        else if(strcmp(op,"DEQUEUE")==0){
            scanf("%d",&q);
            q--;

            if(front[q]==-1 || front[q]>rear[q]){
                printf("Queue Underflow\n");
            }else{
                printf("%d\n",arr[q*size + front[q]]);
                front[q]++;
            }
        }

        else if(strcmp(op,"PEEK")==0){
            scanf("%d",&q);
            q--;

            if(front[q]==-1 || front[q]>rear[q]){
                printf("Queue Underflow\n");
            }else{
                printf("%d\n",arr[q*size + front[q]]);
            }
        }

        else if(strcmp(op,"DISPLAY")==0){
            scanf("%d",&q);
            q--;

            if(front[q]==-1 || front[q]>rear[q]){
                printf("Queue Underflow\n");
            }else{
                for(int i=front[q];i<=rear[q];i++)
                    printf("%d ",arr[q*size + i]);
                printf("\n");
            }
        }
    }

    return 0;
}
