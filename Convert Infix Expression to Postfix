#include <stdio.h>
#include <ctype.h>
#include <string.h>

char stack[100];
int top=-1;

void push(char x){
    stack[++top]=x;
}

char pop(){
    return stack[top--];
}

int precedence(char x){
    if(x=='^') return 3;
    if(x=='*'||x=='/') return 2;
    if(x=='+'||x=='-') return 1;
    return 0;
}

int main(){
    char infix[100],postfix[100];
    scanf("%s",infix);
    
    int i,j=0;
    
    for(i=0;i<strlen(infix);i++){
        char ch=infix[i];
        
        if(isalnum(ch)){
            postfix[j++]=ch;
        }
        else if(ch=='('){
            push(ch);
        }
        else if(ch==')'){
            while(stack[top]!='(')
                postfix[j++]=pop();
            pop();
        }
        else{
            while(top!=-1 && precedence(stack[top])>=precedence(ch))
                postfix[j++]=pop();
            push(ch);
        }
    }
    
    while(top!=-1)
        postfix[j++]=pop();
    
    postfix[j]='\0';
    
    printf("%s",postfix);
    
    return 0;
}
